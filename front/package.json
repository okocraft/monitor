{
    "name": "front",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "check": "pnpm biome check ./",
